{{ 'wishlist.css' | asset_url | stylesheet_tag }}

<div
  class="wbify-page"
  data-wishlist-page
  data-heading="{{ block.settings.heading | escape }}"
  data-empty-text="{{ block.settings.empty_text | escape }}"
  data-clear-text="{{ block.settings.clear_text | escape }}"
  data-add-all-text="{{ block.settings.add_all_text | escape }}"
  data-share-title="{{ block.settings.share_title | escape }}"
  data-share-text="{{ block.settings.share_text | escape }}"
  data-email-enabled="{{ block.settings.show_email_form }}"
  data-email-heading="{{ block.settings.email_heading | escape }}"
  data-email-placeholder="{{ block.settings.email_placeholder | escape }}"
  data-email-submit="{{ block.settings.email_submit | escape }}"
  data-email-success="{{ block.settings.email_success | escape }}"
  data-proxy-url="/apps/wishlist"
  {{ block.shopify_attributes }}
>
  <p class="wbify-loading-state">{{ block.settings.loading_text }}</p>
</div>

<script src="{{ 'wishlist.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Wishlist Page",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "Page"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "My Wishlist"
    },
    {
      "type": "text",
      "id": "empty_text",
      "label": "Empty wishlist message",
      "default": "Your wishlist is empty. Start adding products you love!"
    },
    {
      "type": "text",
      "id": "loading_text",
      "label": "Loading message",
      "default": "Loading your wishlist…"
    },
    {
      "type": "text",
      "id": "clear_text",
      "label": "Clear wishlist label",
      "default": "Clear Wishlist"
    },
    {
      "type": "text",
      "id": "add_all_text",
      "label": "Add all to cart label",
      "default": "Add All to Cart"
    },
    {
      "type": "header",
      "content": "Share Wishlist"
    },
    {
      "type": "text",
      "id": "share_title",
      "label": "Share section heading",
      "default": "Share your Wishlist"
    },
    {
      "type": "text",
      "id": "share_text",
      "label": "Social share message",
      "default": "Check out my wishlist!"
    },
    {
      "type": "header",
      "content": "Email Reminder"
    },
    {
      "type": "checkbox",
      "id": "show_email_form",
      "label": "Show email reminder form",
      "default": true
    },
    {
      "type": "text",
      "id": "email_heading",
      "label": "Email section heading",
      "default": "Never lose your Wishlist"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email input placeholder",
      "default": "Enter your email address"
    },
    {
      "type": "text",
      "id": "email_submit",
      "label": "Email submit label",
      "default": "Send me a reminder"
    },
    {
      "type": "text",
      "id": "email_success",
      "label": "Success message",
      "default": "Done! We'll remind you about your wishlist."
    }
  ]
}
{% endschema %}
